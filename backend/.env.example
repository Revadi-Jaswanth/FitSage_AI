# ==========================================
# FitSage AI - Environment Variables Template
# Copy this file to '.env' and fill in values.
# ==========================================

# 1. MySQL Database Configuration Settings
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_secure_mysql_root_password_here
DB_NAME=fitsage_db

# 2. JWT Configuration Settings
# Generate a secure key using: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=generate_and_replace_this_with_your_own_jwt_secret_key

# 3. Google Gemini AI Engine Configuration
GEMINI_API_KEY=your_google_gemini_developer_api_key_here

# 4. Centralized LLM Model Control Parameters
AI_MODEL=gemini-2.5-flash
AI_TEMPERATURE=0.6
AI_MAX_OUTPUT_TOKENS=4096
